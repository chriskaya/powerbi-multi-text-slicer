{
    "compilerOptions": {
        "allowJs": false,
        "target": "ES2022",
        "module": "esnext",
        "moduleResolution": "node",
        "sourceMap": true,
        "outDir": "./.tmp/build/",
        "declaration": true,
        "noImplicitAny": false,
        "skipLibCheck": true,
        "noEmitOnError": true,
        "experimentalDecorators": true,
        "preserveConstEnums": true,
        "strictNullChecks": true,
        "lib": ["ES2022", "DOM"]
    },
    "include": ["src/**/*.ts"],
    "files": ["./src/visual.ts"]
}
